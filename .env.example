RESEARCH_COPILOT_APP_NAME=Research Copilot API

# Postgres connection parts (used when DATABASE_URL is not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=research_copilot
POSTGRES_USER=research_copilot
POSTGRES_PASSWORD=research_copilot

# Optional explicit DSN override
DATABASE_URL=postgresql+psycopg://research_copilot:research_copilot@localhost:5432/research_copilot

# Local file storage for uploaded documents
STORAGE_DIR=storage/documents

# Stage 2 chunking and embedding configuration
CHUNK_SIZE=800
CHUNK_OVERLAP=120
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SIMILARITY=0.2
